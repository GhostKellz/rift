{
  "name": "rift-kwin",
  "version": "0.1.0",
  "private": true,
  "description": "Thin KWin agent for the Rift tiling daemon",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "esbuild src/main.ts --bundle --format=iife --target=es2019 --outfile=contents/code/main.js",
    "build:harness": "esbuild src/protocol.ts --bundle --format=esm --target=es2020 --outfile=dist/protocol.mjs",
    "typecheck": "tsc --noEmit",
    "test": "npm run build:harness && node --test test/handshake.test.mjs"
  },
  "devDependencies": {
    "esbuild": "^0.24.0",
    "typescript": "^5.6.0"
  }
}
